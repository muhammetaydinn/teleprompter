{
  "name": "teleprompter-desktop",
  "version": "0.1.0",
  "description": "Cross-platform desktop teleprompter MVP",
  "author": "Muhammet",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "icons:generate": "mkdir -p build/icons && icon-gen -i build/icon.svg -o build/icons --ico --icns --favicon --favicon-name icon --favicon-png-sizes 64,128,256,512 --favicon-ico-sizes 16,24,32,48 --ico-name icon --icns-name icon --report",
    "release": "npm run icons:generate && electron-builder",
    "release:linux": "npm run icons:generate && electron-builder --linux AppImage",
    "release:win": "npm run icons:generate && electron-builder --win zip --config.win.signAndEditExecutable=false",
    "release:mac": "npm run icons:generate && electron-builder --mac zip",
    "release:all": "npm run icons:generate && electron-builder -mwl",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "build": {
    "appId": "com.teleprompter.desktop",
    "productName": "Teleprompter Desktop",
    "asar": true,
    "afterSign": "scripts/notarize.js",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build/icons"
    },
    "win": {
      "signAndEditExecutable": false,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.22.0",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "icon-gen": "^5.0.0",
    "prettier": "^3.5.3"
  }
}
