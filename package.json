{
  "name": "teleprompter-desktop",
  "version": "0.1.0",
  "description": "Cross-platform desktop teleprompter MVP",
  "author": "Muhammet",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "release": "electron-builder",
    "release:linux": "electron-builder --linux AppImage",
    "release:win": "electron-builder --win zip --config.win.signAndEditExecutable=false",
    "release:mac": "electron-builder --mac zip",
    "release:all": "electron-builder -mwl",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "build": {
    "appId": "com.teleprompter.desktop",
    "productName": "Teleprompter Desktop",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3"
  }
}
