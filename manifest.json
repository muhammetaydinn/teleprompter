{
  "manifest_version": 3,
  "name": "Teleprompter",
  "version": "1.0.0",
  "description": "Herhangi bir web sayfası üzerinde teleprompter overlay",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "Teleprompter"
  }
}
